<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Menu Coffee 99</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="menu-reference-page">
  <%- include('partials/header') %>

  <main class="container menu-reference-container">
    <div class="menu-topbar">
      <div class="menu-search">
        <i class="bi bi-search menu-search-icon" aria-hidden="true"></i>
        <input
          type="search"
          id="menuSearchInput"
          class="form-control menu-search-input"
          placeholder="Search"
          aria-label="Cari menu kopi"
        >
      </div>
      <a href="/orders/cart" class="menu-cart-link" aria-label="Lihat keranjang">
        <i class="bi bi-cart3"></i>
      </a>
    </div>

    <h1 class="menu-page-title">Coffee Menu</h1>

    <% if (successMessage) { %>
      <div class="alert alert-success menu-success-alert"><%= successMessage %></div>
    <% } %>

    <div class="row g-4 g-lg-5" id="menuProductGrid">
      <% products.forEach(product => { %>
        <div
          class="col-6 col-md-4 js-menu-item"
          data-name="<%= (product.name || '').toLowerCase() %>"
          data-description="<%= (product.description || '').toLowerCase() %>"
        >
          <article class="menu-item-card">
            <img
              src="/images/<%= product.image || 'default-coffee.jpg' %>"
              class="menu-item-image"
              alt="<%= product.name %>"
            >
            <div class="menu-item-content">
              <h2 class="menu-item-name"><%= product.name %></h2>
              <p class="menu-item-description"><%= product.description %></p>
              <p class="menu-item-price">Rp <%= product.price.toLocaleString("id-ID") %></p>

              <form action="/orders/cart/add" method="POST" class="menu-item-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="product_id" value="<%= product.id %>">
                <div class="input-group input-group-sm">
                  <input
                    type="number"
                    name="quantity"
                    class="form-control"
                    value="1"
                    min="1"
                    max="99"
                    required
                    aria-label="Jumlah <%= product.name %>"
                  >
                  <button type="submit" class="btn btn-success">Tambah</button>
                </div>
              </form>
            </div>
          </article>
        </div>
      <% }) %>
    </div>
    <div id="menuNoResults" class="menu-no-results d-none">
      Menu tidak ditemukan.
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (() => {
      const searchInput = document.getElementById("menuSearchInput");
      const items = Array.from(document.querySelectorAll(".js-menu-item"));
      const noResults = document.getElementById("menuNoResults");

      function normalize(value) {
        return String(value || "").toLowerCase().trim();
      }

      function filterMenu(rawQuery) {
        const query = normalize(rawQuery);
        let visibleCount = 0;

        items.forEach((item) => {
          const keyword = normalize(item.dataset.name + " " + item.dataset.description);
          const isMatch = keyword.includes(query);
          item.classList.toggle("d-none", !isMatch);
          if (isMatch) visibleCount += 1;
        });

        noResults.classList.toggle("d-none", visibleCount > 0);
      }

      filterMenu("");
      if (!searchInput) return;

      searchInput.addEventListener("input", (event) => {
        filterMenu(event.target.value);
      });
    })();
  </script>
</body>
</html>
